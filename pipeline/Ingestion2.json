{
	"name": "Ingestion2",
	"properties": {
		"activities": [
			{
				"name": "Lookup1",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "@concat('select * from [Project].[config] where status = ''',pipeline().parameters.pp_status,''' and project = ''',pipeline().parameters.pp_project,'''' )",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "IngestionAzuresql",
						"type": "DatasetReference"
					}
				}
			}
		],
		"parameters": {
			"pp_project": {
				"type": "string",
				"defaultValue": "sales"
			},
			"pp_status": {
				"type": "string",
				"defaultValue": "Active"
			}
		},
		"annotations": []
	}
}